---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Login from "../../components/auth/Login";
---

<BaseLayout title="Log in">
	<div class="fixed top-4 left-4 z-50 flex items-center gap-3 px-4 py-2 bg-sky-300/30 backdrop-blur-sm rounded-md"> <!--bg-white/80  rounded-xl shadow-md backdrop-blur-md"-->
		<img src="/assets/logo.jpg" alt="Logo" class="h-10 w-10 rounded-full border border-gray-200 shadow-sm"/>
		<h1 class="text-2xl font-bold text-gray-800">Maths with SD</h1>
	</div>
	<Login client:load />
</BaseLayout>